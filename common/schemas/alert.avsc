{
  "type": "record",
  "name": "Alert",
  "namespace": "com.ews",
  "fields": [
    {"name": "alert_id", "type": "string"},
    {"name": "area_id", "type": "string"},
    {"name": "timestamp", "type": "string"},
    {"name": "disaster_type", "type": "com.ews.enums.DisasterType"},
    {"name": "current_measurement", "type": {"type": "array", "items": "com.ews.common.Measurement"}},
    {"name": "alert_level", "type": "com.ews.enums.AlertLevel"},
    {"name": "title", "type": "string"},
    {"name": "message", "type": "string"}
  ]
}